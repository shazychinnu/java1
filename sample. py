python3 << 'EOF'
import zipfile

# Check what's in a normal openpyxl-saved xlsx
from openpyxl import Workbook
from io import BytesIO

wb = Workbook()
buf = BytesIO()
wb.save(buf)
xlsx_bytes = buf.getvalue()

with zipfile.ZipFile(BytesIO(xlsx_bytes), "r") as z:
    print("Normal openpyxl xlsx files:")
    for f in z.namelist():
        print(" ", f)
    print("\nworkbook.xml.rels:")
    print(z.read("xl/_rels/workbook.xml.rels").decode())
EOF