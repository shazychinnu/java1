from openpyxl import load_workbook
from io import BytesIO
import zipfile, shutil

# Test: can we copy sheets from xlsx into xlsm?
# Load template xlsm
template_path = "/tmp/vba_template_debug.xlsm"

with open(template_path, "rb") as f:
    template_bytes = f.read()

print("Template size:", len(template_bytes))

# List template sheets
with zipfile.ZipFile(BytesIO(template_bytes), "r") as z:
    print("Template files:", z.namelist())
    rels = z.read("xl/_rels/workbook.xml.rels").decode()
    print("Rels:", rels[:500])
