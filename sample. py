import zipfile
from io import BytesIO
from openpyxl import Workbook

def merge_xlsx_into_xlsm(xlsx_bytes, xlsm_bytes):
    xlsx_files = {}
    with zipfile.ZipFile(BytesIO(xlsx_bytes), "r") as z:
        for name in z.namelist():
            xlsx_files[name] = z.read(name)
    
    xlsm_files = {}
    with zipfile.ZipFile(BytesIO(xlsm_bytes), "r") as z:
        for name in z.namelist():
            xlsm_files[name] = z.read(name)
    
    output = BytesIO()
    with zipfile.ZipFile(output, "w", zipfile.ZIP_DEFLATED) as zout:
        for path, data in xlsm_files.items():
            if path.startswith("xl/worksheets/"):
                continue
            elif path == "xl/workbook.xml":
                zout.writestr(path, xlsx_files.get(path, data))
            elif path == "xl/_rels/workbook.xml.rels":
                xlsx_rels = xlsx_files.get(path, b"").decode()
                if "vbaProject" not in xlsx_rels:
                    xlsx_rels = xlsx_rels.replace(
                        "</Relationships>",
                        '<Relationship Id="rIdVBA1" '
                        'Type="http://schemas.microsoft.com/office/'
                        '2006/relationships/vbaProject" '
                        'Target="vbaProject.bin"/>'
                        "</Relationships>"
                    )
                zout.writestr(path, xlsx_rels.encode())
            elif path == "[Content_Types].xml":
                content = xlsx_files.get(path, data).decode()
                content = content.replace(
                    'ContentType="application/vnd.openxmlformats-officedocument'
                    '.spreadsheetml.sheet.main+xml"',
                    'ContentType="application/vnd.ms-excel.sheet'
                    '.macroEnabled.main+xml"'
                )
                if "vbaProject.bin" not in content:
                    content = content.replace(
                        "</Types>",
                        '<Override PartName="/xl/vbaProject.bin" '
                        'ContentType="application/vnd.ms-office.vbaProject"/>'
                        "</Types>"
                    )
                zout.writestr(path, content.encode())
            elif path == "xl/styles.xml":
                zout.writestr(path, xlsx_files.get(path, data))
            else:
                zout.writestr(path, data)
        
        for path, data in xlsx_files.items():
            if path.startswith("xl/worksheets/") or \
               path.startswith("xl/worksheets/_rels/") or \
               path.startswith("xl/drawings/") or \
               path.startswith("xl/drawings/_rels/") or \
               path.startswith("xl/media/") or \
               path == "xl/sharedStrings.xml":
                zout.writestr(path, data)
    
    return output.getvalue()

wb = Workbook()
