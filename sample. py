with open("/tmp/vba_template_debug.xlsm", "rb") as f:
    xlsm_bytes = f.read()

result = merge_xlsx_into_xlsm(xlsx_bytes, xlsm_bytes)
with open("/tmp/test_merged.xlsm", "wb") as f:
    f.write(result)

print("Done! Size:", len(result))
with zipfile.ZipFile(BytesIO(result), "r") as z:
    print("Files:", z.namelist())
